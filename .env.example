# ─── MONITRA — Environment Variables ────────────────────────────────────────
# Salin file ini menjadi .env dan isi sesuai konfigurasi
# cp .env.example .env

# ─── SERVER ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# URL publik aplikasi (ganti dengan domain Railway kamu)
# Contoh: https://monitra-production.up.railway.app
APP_URL=https://your-app.up.railway.app

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Path ke file SQLite — di Railway: set ke /data/audit_system.db (Railway Volume)
# Di local: kosongkan / hapus baris ini (default: audit_system.db di root project)
DB_PATH=/data/audit_system.db

# ─── SMTP (opsional jika sudah diset dari halaman Admin → Konfigurasi Email) ──
# Contoh untuk Gmail:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=MONITRA <your_email@gmail.com>

# ─── CATATAN untuk Gmail ─────────────────────────────────────────────────────
# 1. Aktifkan 2-Step Verification di akun Google Anda
# 2. Buka: https://myaccount.google.com/apppasswords
# 3. Buat App Password baru → kategori "Mail", device "Windows Computer"
# 4. Gunakan 16-digit App Password di SMTP_PASS (tanpa spasi)
